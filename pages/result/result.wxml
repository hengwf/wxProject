<view class="container">
  <!-- 结果展示 -->
  <view class="result-card">
    <view class="result-icon {{isPass ? 'pass' : 'fail'}}">
      {{isPass ? '🎉' : '😢'}}
    </view>
    <text class="result-title">{{isPass ? '恭喜通关！' : '继续加油！'}}</text>
    <text class="result-stars">{{getStars()}}</text>
    <text class="result-comment">{{getComment()}}</text>
  </view>

  <!-- 成绩统计 -->
  <view class="stats-card">
    <view class="stats-row">
      <text class="stats-label">正确率</text>
      <text class="stats-value {{isPass ? 'pass' : 'fail'}}">{{correctRate}}%</text>
    </view>
    <view class="stats-row">
      <text class="stats-label">答对题数</text>
      <text class="stats-value">{{correctCount}} / {{totalQuestions}}</text>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-list">
    <view class="action-btn primary" bindtap="retry">
      <text>重新挑战</text>
    </view>
    <view wx:if="{{isPass}}" class="action-btn" bindtap="nextChapter">
      <text>下一章</text>
    </view>
    <view class="action-btn" bindtap="backToChapters">
      <text>章节列表</text>
    </view>
    <view class="action-btn" bindtap="backToHome">
      <text>返回首页</text>
    </view>
  </view>
</view>
