.result-card {
  text-align: center;
  padding: 48rpx !important;
  color: #ffffff;
  margin-bottom: 32rpx;
  position: relative;
  overflow: hidden;
  animation: cardFloat 3s ease-in-out infinite;
}

@keyframes cardFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8rpx); }
}

.result-card::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%);
  animation: cardShine 4s ease-in-out infinite;
}

@keyframes cardShine {
  0%, 100% { transform: translate(-20%, -20%) scale(0.8); opacity: 0; }
  50% { transform: translate(20%, 20%) scale(1.2); opacity: 1; }
}

.result-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
  display: inline-block;
  animation: iconBounce 1s ease-in-out infinite;
  filter: drop-shadow(0 8rpx 24rpx rgba(0, 0, 0, 0.3));
}

@keyframes iconBounce {
  0%, 100% { transform: translateY(0) scale(1); }
  50% { transform: translateY(-12rpx) scale(1.1); }
}

.result-title {
  font-size: 48rpx;
  font-weight: 900;
  margin-bottom: 16rpx;
  text-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.2);
  letter-spacing: 3rpx;
}

.result-sub {
  font-size: 32rpx;
  opacity: 0.95;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.stats-card {
  margin-bottom: 32rpx;
  position: relative;
  z-index: 1;
}

.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.stat-item {
  text-align: center;
  flex: 1;
  padding: 16rpx 8rpx;
  animation: statPop 0.6s cubic-bezier(0.68, -0.55, 0.265, 1.55);
}

.stat-item:nth-child(1) { animation-delay: 0.1s; }
.stat-item:nth-child(2) { animation-delay: 0.2s; }
.stat-item:nth-child(3) { animation-delay: 0.3s; }

@keyframes statPop {
  0% { transform: scale(0.5); opacity: 0; }
  50% { transform: scale(1.1); }
  100% { transform: scale(1); opacity: 1; }
}

.stat-value {
  font-size: 56rpx;
  font-weight: 900;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 12rpx;
  text-shadow: none;
}

.stat-label {
  font-size: 26rpx;
  color: #888;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.stat-divider {
  width: 3rpx;
  height: 72rpx;
  background: linear-gradient(180deg, transparent 0%, #e0e0e0 50%, transparent 100%);
  border-radius: 2rpx;
}

.rate-card {
  text-align: center;
  margin-bottom: 48rpx;
  position: relative;
  z-index: 1;
}

.rate-title {
  font-size: 30rpx;
  color: #999;
  margin-bottom: 20rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.rate-stars {
  font-size: 56rpx;
  margin-bottom: 20rpx;
  display: inline-block;
  animation: starsGlow 2s ease-in-out infinite;
}

@keyframes starsGlow {
  0%, 100% { filter: drop-shadow(0 0 8rpx rgba(255, 193, 7, 0.5)); }
  50% { filter: drop-shadow(0 0 16rpx rgba(255, 193, 7, 0.8)); }
}

.rate-comment {
  font-size: 30rpx;
  color: #666;
  font-weight: 600;
  line-height: 1.6;
}

.action-buttons {
  display: flex;
  gap: 24rpx;
  position: relative;
  z-index: 1;
}

.retry-btn, .next-btn {
  flex: 1;
  padding: 32rpx !important;
  font-size: 32rpx;
  font-weight: 700;
}

.retry-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.retry-btn::before {
  content: '🔄';
  font-size: 32rpx;
  animation: retrySpin 2s linear infinite;
}

@keyframes retrySpin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.next-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.next-btn::after {
  content: '→';
  font-size: 32rpx;
  animation: nextArrow 1s ease-in-out infinite;
}

@keyframes nextArrow {
  0%, 100% { transform: translateX(0); }
  50% { transform: translateX(6rpx); }
}