.container {
  min-height: 100vh;
  background: #f0f5f9;
  padding: 40rpx 30rpx;
}

.result-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 40rpx rgba(0,0,0,0.1);
}

.result-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.result-icon.pass {
  animation: bounce 0.5s ease;
}

.result-icon.fail {
  opacity: 0.8;
}

@keyframes bounce {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.result-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.result-stars {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.result-comment {
  font-size: 28rpx;
  color: #666;
}

.stats-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.stats-row {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.stats-row:last-child {
  border-bottom: none;
}

.stats-label {
  font-size: 28rpx;
  color: #666;
}

.stats-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.stats-value.pass {
  color: #52c41a;
}

.stats-value.fail {
  color: #ff4d4f;
}

.action-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.action-btn {
  background: #fff;
  border-radius: 50rpx;
  padding: 30rpx;
  text-align: center;
  font-size: 32rpx;
  color: #333;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.action-btn.primary {
  background: linear-gradient(135deg, #1890ff, #096dd9);
  color: #fff;
}

.action-btn:active {
  opacity: 0.8;
}
