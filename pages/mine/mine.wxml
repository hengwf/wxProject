<view class="container">
  <!-- 用户信息 -->
  <view class="user-card" bindtap="goToProfile">
    <view class="user-avatar">{{userData.avatar || '👨‍⚕️'}}</view>
    <view class="user-info">
      <text class="user-name">{{userData.nickname || '医学考生'}}</text>
      <text class="user-status {{memberStatus === 'vip' ? 'vip' : ''}}">{{getMemberStatusText()}}</text>
    </view>
    <view wx:if="{{memberStatus !== 'vip'}}" class="vip-btn" bindtap="goToVip">
      <text>开通会员</text>
    </view>
    <text class="edit-icon">›</text>
  </view>

  <!-- 统计 -->
  <view class="stats-card">
    <view class="stats-item">
      <text class="stats-num">{{userData.totalQuestions || 0}}</text>
      <text class="stats-label">累计答题</text>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item">
      <text class="stats-num">{{correctRate}}%</text>
      <text class="stats-label">正确率</text>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item">
      <text class="stats-num">{{totalCompletedChapters}}</text>
      <text class="stats-label">已通关章节</text>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="menu-item" bindtap="goToWrong">
      <text class="menu-icon">📖</text>
      <text class="menu-text">错题本</text>
      <view class="menu-badge" wx:if="{{wrongCount > 0}}">{{wrongCount}}</view>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="goToVip">
      <text class="menu-icon">👑</text>
      <text class="menu-text">会员中心</text>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item" bindtap="goToRules">
      <text class="menu-icon">📜</text>
      <text class="menu-text">用户规则</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="goToPrivacy">
      <text class="menu-icon">🔒</text>
      <text class="menu-text">隐私政策</text>
      <text class="menu-arrow">></text>
    </view>
    <view class="menu-item" bindtap="showAbout">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于我们</text>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <view class="menu-section">
    <view class="menu-item danger" bindtap="clearData">
      <text class="menu-icon">🗑️</text>
      <text class="menu-text">清除数据</text>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text>医考通 v1.0.0</text>
  </view>
</view>
