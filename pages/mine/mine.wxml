<view class="container">
  <view class="user-card card">
    <view class="avatar">👤</view>
    <view class="user-info">
      <view class="user-name">益智挑战者</view>
      <view class="user-title">知识达人</view>
    </view>
  </view>

  <view class="stats-section card">
    <view class="section-title">📊 我的数据</view>
    <view class="stats-grid">
      <view class="stat-item">
        <view class="stat-value">{{userData.totalQuestions}}</view>
        <view class="stat-label">总答题数</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">{{correctRate}}%</view>
        <view class="stat-label">正确率</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">{{totalCompletedLevels}}</view>
        <view class="stat-label">已通关</view>
      </view>
      <view class="stat-item">
        <view class="stat-value">{{totalUnlockedLevels}}</view>
        <view class="stat-label">已解锁</view>
      </view>
    </view>
  </view>

  <view class="progress-section card">
    <view class="section-title">📈 分类进度</view>
    <view class="progress-list">
      <view wx:for="{{categories}}" wx:key="id" class="progress-item">
        <view class="progress-header">
          <text class="category-icon">{{item.icon}}</text>
          <text class="category-name">{{item.name}}</text>
          <text class="progress-text">{{getCategoryProgress(item.id)}}</text>
        </view>
        <view class="progress-bar">
          <view 
            class="progress-fill" 
            style="width: {{getProgressPercent(item.id)}}%; background: {{item.color}};"
          ></view>
        </view>
      </view>
    </view>
  </view>

  <view class="menu-section card">
    <view class="menu-item" bindtap="goToRules">
      <text class="menu-icon">📋</text>
      <text class="menu-text">游戏规则</text>
      <text class="menu-arrow">→</text>
    </view>
    <view class="menu-item" bindtap="goToPrivacy">
      <text class="menu-icon">🔒</text>
      <text class="menu-text">隐私政策</text>
      <text class="menu-arrow">→</text>
    </view>
    <view class="menu-item" bindtap="showAbout">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于我们</text>
      <text class="menu-arrow">→</text>
    </view>
  </view>

  <view class="clear-btn" bindtap="clearData">
    <text>🗑️ 清除数据</text>
  </view>
</view>