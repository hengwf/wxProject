.user-card {
  display: flex;
  align-items: center;
  padding: 30rpx !important;
  background: linear-gradient(135deg, #4a90d9 0%, #357abd 100%) !important;
  color: #ffffff;
}

.avatar {
  font-size: 72rpx;
  margin-right: 24rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.user-title {
  font-size: 26rpx;
  opacity: 0.85;
}

.stats-section {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
}

.stats-grid {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #4a90d9;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999999;
}

.progress-section {
  margin-bottom: 20rpx;
}

.progress-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.progress-item {
  display: flex;
  flex-direction: column;
}

.progress-header {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.category-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.category-name {
  flex: 1;
  font-size: 26rpx;
  color: #333333;
}

.progress-text {
  font-size: 24rpx;
  color: #999999;
}

.progress-bar {
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.menu-section {
  margin-bottom: 20rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 32rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 30rpx;
  color: #333333;
}

.menu-arrow {
  font-size: 32rpx;
  color: #cccccc;
}

.clear-btn {
  text-align: center;
  padding: 24rpx;
  color: #999999;
  font-size: 26rpx;
}

.clear-btn:active {
  opacity: 0.7;
}