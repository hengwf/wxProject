.container {
  min-height: 100vh;
  background: #f0f5f9;
  padding: 0 30rpx 100rpx;
}

.user-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #1890ff, #096dd9);
  color: #fff;
  padding: 40rpx 30rpx;
  border-radius: 0 0 40rpx 40rpx;
  margin: 0 -30rpx;
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 50rpx;
  margin-right: 24rpx;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
}

.user-status {
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 6rpx;
}

.user-status.vip {
  color: #ffd700;
}

.vip-btn {
  background: rgba(255,255,255,0.2);
  padding: 16rpx 24rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  margin-right: 16rpx;
}

.edit-icon {
  font-size: 40rpx;
  opacity: 0.7;
}

.stats-card {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  margin: 30rpx 0;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.stats-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-num {
  font-size: 40rpx;
  font-weight: bold;
  color: #1890ff;
}

.stats-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.stats-divider {
  width: 1rpx;
  height: 60rpx;
  background: #eee;
  margin-top: 10rpx;
}

.menu-section {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item.danger .menu-icon,
.menu-item.danger .menu-text {
  color: #ff4d4f;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.menu-badge {
  background: #ff4d4f;
  color: #fff;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-right: 16rpx;
}

.menu-arrow {
  font-size: 28rpx;
  color: #ccc;
}

.version-info {
  text-align: center;
  padding: 40rpx;
  font-size: 24rpx;
  color: #ccc;
}
