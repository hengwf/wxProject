.container {
  padding: 40rpx 30rpx;
  min-height: 100vh;
  background-color: #f0f5f9;
}

/* 头像区域 */
.avatar-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 50rpx;
}

.avatar-wrapper {
  position: relative;
  width: 160rpx;
  height: 160rpx;
}

.avatar-display {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background-color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 80rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.avatar-edit {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background-color: #1890ff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(24, 144, 255, 0.4);
}

.edit-icon {
  font-size: 28rpx;
}

.avatar-tip {
  font-size: 26rpx;
  color: #999999;
  margin-top: 20rpx;
}

/* 字段区域 */
.field-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.field-label {
  font-size: 28rpx;
  color: #333333;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.field-input-wrapper {
  display: flex;
  align-items: center;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}

.field-input {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

/* 文本域 */
.field-textarea-wrapper {
  position: relative;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}

.field-textarea {
  width: 100%;
  min-height: 120rpx;
  font-size: 28rpx;
  color: #333333;
}

.char-count {
  position: absolute;
  bottom: 12rpx;
  right: 24rpx;
  font-size: 24rpx;
  color: #999999;
}

/* 备考目标 */
.goal-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.goal-item {
  flex: 1;
  min-width: calc(50% - 10rpx);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  background-color: #ffffff;
  transition: all 0.3s;
}

.goal-item.selected {
  border-color: #1890ff;
  background-color: #e6f7ff;
}

.goal-text {
  font-size: 28rpx;
  color: #333333;
}

.goal-check {
  font-size: 32rpx;
  color: #1890ff;
  font-weight: bold;
}

/* 保存按钮 */
.save-btn {
  width: 100%;
  padding: 32rpx;
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(24, 144, 255, 0.3);
  margin: 40rpx 0;
}

.save-btn text {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: bold;
}

/* 快捷头像 */
.quick-avatar-section {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.section-title {
  font-size: 28rpx;
  color: #333333;
  font-weight: bold;
  margin-bottom: 24rpx;
}

.quick-avatar-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.quick-avatar-item {
  width: 96rpx;
  height: 96rpx;
  border-radius: 12rpx;
  background-color: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  border: 3rpx solid transparent;
  transition: all 0.3s;
}

.quick-avatar-item.selected {
  border-color: #1890ff;
  background-color: #e6f7ff;
}
