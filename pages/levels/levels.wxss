.category-header {
  display: flex;
  align-items: center;
  padding: 30rpx !important;
  background: linear-gradient(135deg, #4a90d9 0%, #357abd 100%) !important;
  color: #ffffff;
}

.category-icon {
  font-size: 56rpx;
  margin-right: 24rpx;
}

.category-info {
  flex: 1;
}

.category-name {
  font-size: 34rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.category-desc {
  font-size: 24rpx;
  opacity: 0.85;
  line-height: 1.4;
}

.levels-title {
  font-size: 32rpx;
  font-weight: 600;
  margin: 30rpx 0 20rpx;
  padding-left: 10rpx;
}

.levels-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.level-item {
  width: calc(33.33% - 14rpx);
  aspect-ratio: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20rpx !important;
  position: relative;
  overflow: hidden;
}

.level-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #4a90d9 0%, #357abd 100%);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.level-item:active::before {
  opacity: 0.1;
}

.level-number {
  font-size: 48rpx;
  font-weight: 700;
  color: #4a90d9;
  margin-bottom: 8rpx;
}

.level-status {
  font-size: 28rpx;
  margin-bottom: 8rpx;
}

.status-locked {
  color: #cccccc;
}

.status-completed {
  color: #52c41a;
}

.status-available {
  color: #4a90d9;
}

.level-label {
  font-size: 22rpx;
  color: #999999;
}

.rules-card {
  margin-top: 30rpx;
}

.rules-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
}

.rules-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.rule-item {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
}