<view class="container">
  <!-- 顶部标题区 -->
  <view class="header">
    <view class="logo-title">
      <text class="title">医考通</text>
      <text class="subtitle">专业医学考试题库</text>
    </view>
    <view class="member-badge" bindtap="goToVip">
      <text wx:if="{{memberStatus === 'vip'}}">会员</text>
      <text wx:else>开通会员</text>
    </view>
  </view>

  <!-- 今日统计 -->
  <view class="stats-card">
    <view class="stats-item">
      <text class="stats-num">{{todayQuestions}}</text>
      <text class="stats-label">今日答题</text>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item">
      <text class="stats-num">{{totalQuestions}}</text>
      <text class="stats-label">累计答题</text>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item">
      <text class="stats-num">{{correctRate}}%</text>
      <text class="stats-label">正确率</text>
    </view>
  </view>

  <!-- 提示语 -->
  <view class="tip-card">
    <text class="tip-icon">💡</text>
    <text class="tip-text">{{currentTip}}</text>
  </view>

  <!-- 题库分类 -->
  <view class="section-title">选择题库开始学习</view>
  <view class="category-list">
    <view
      wx:for="{{categories}}"
      wx:key="id"
      class="category-item"
      style="border-left: 8rpx solid {{item.color}}"
      bindtap="goToChapters"
      data-category="{{item.id}}"
    >
      <view class="category-left">
        <text class="category-icon">{{item.icon}}</text>
        <view class="category-info">
          <text class="category-name">{{item.name}}</text>
          <text class="category-desc">{{item.desc}}</text>
        </view>
      </view>
      <view class="category-right">
        <text class="category-progress">{{getCategoryProgress(item.id)}}</text>
        <view class="progress-bar">
          <view class="progress-fill" style="width: {{getProgressPercent(item.id)}}%; background: {{item.color}}"></view>
        </view>
        <text class="category-arrow">></text>
      </view>
    </view>
  </view>

  <!-- 底部留白 -->
  <view class="bottom-space"></view>
</view>
