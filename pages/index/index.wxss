.header {
  text-align: center;
  padding: 40rpx 0 30rpx;
}

.logo {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 10rpx;
}

.logo-icon {
  font-size: 60rpx;
  margin-right: 16rpx;
}

.logo-text {
  font-size: 48rpx;
  font-weight: 700;
  color: #4a90d9;
}

.subtitle {
  font-size: 26rpx;
  color: #999999;
}

.stats-card {
  text-align: center;
  background: linear-gradient(135deg, #4a90d9 0%, #357abd 100%) !important;
  color: #ffffff;
}

.stats-title {
  font-size: 26rpx;
  opacity: 0.8;
  margin-bottom: 10rpx;
}

.stats-value {
  font-size: 72rpx;
  font-weight: 700;
  line-height: 1;
}

.stats-sub {
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 10rpx;
}

.categories-title {
  font-size: 32rpx;
  font-weight: 600;
  margin: 30rpx 0 20rpx;
  padding-left: 10rpx;
}

.categories {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.category-card {
  display: flex;
  align-items: center;
  padding: 30rpx !important;
}

.category-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.category-info {
  flex: 1;
}

.category-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
}

.category-progress {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.progress-bar {
  flex: 1;
  height: 8rpx;
  background: #f0f0f0;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 22rpx;
  color: #999999;
  margin-left: 12rpx;
  min-width: 60rpx;
}

.category-level {
  font-size: 22rpx;
  color: #999999;
}

.category-arrow {
  font-size: 36rpx;
  color: #cccccc;
  margin-left: 16rpx;
}

.tips-card {
  display: flex;
  padding: 24rpx !important;
  background: linear-gradient(135deg, #fffbe6 0%, #fff5c3 100%) !important;
  border: 2rpx solid #ffe58f;
}

.tips-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.tips-content {
  flex: 1;
}

.tips-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #d4a017;
  margin-bottom: 8rpx;
}

.tips-text {
  font-size: 24rpx;
  color: #8b6914;
  line-height: 1.5;
}

.nav-button {
  margin-top: 20rpx;
  text-align: center;
}