.container {
  min-height: 100vh;
  background: #f0f5f9;
  padding: 0 30rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx 0 30rpx;
}

.logo-title {
  display: flex;
  flex-direction: column;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #1890ff;
}

.subtitle {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.member-badge {
  background: linear-gradient(135deg, #fa8c16, #ff6b00);
  color: #fff;
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
}

.stats-card {
  display: flex;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.stats-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-num {
  font-size: 40rpx;
  font-weight: bold;
  color: #1890ff;
}

.stats-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.stats-divider {
  width: 1rpx;
  height: 60rpx;
  background: #eee;
  margin-top: 10rpx;
}

.tip-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.tip-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #666;
  flex: 1;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.category-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.category-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.category-left {
  display: flex;
  align-items: center;
}

.category-icon {
  font-size: 56rpx;
  margin-right: 20rpx;
}

.category-info {
  display: flex;
  flex-direction: column;
}

.category-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.category-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.category-right {
  display: flex;
  align-items: center;
}

.category-progress {
  font-size: 24rpx;
  color: #999;
  margin-right: 16rpx;
}

.progress-bar {
  width: 100rpx;
  height: 8rpx;
  background: #eee;
  border-radius: 4rpx;
  overflow: hidden;
  margin-right: 16rpx;
}

.progress-fill {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.3s;
}

.category-arrow {
  font-size: 28rpx;
  color: #ccc;
}

.bottom-space {
  height: 200rpx;
}
