<view class="container">
  <view class="quiz-header">
    <view class="progress-info">
      <view class="progress-bar">
        <view class="progress-fill" style="width: {{progressPercent}}%"></view>
      </view>
      <view class="progress-text">{{currentIndex + 1}}/{{totalQuestions}}</view>
    </view>
    <view class="score-info">
      <text class="correct-icon">✓</text>
      <text class="correct-count">{{correctCount}}</text>
    </view>
  </view>

  <view class="question-card card">
    <view class="question-number">第 {{currentIndex + 1}} 题</view>
    <view class="question-text">{{currentQuestion.question}}</view>
  </view>

  <view class="options-list">
    <view 
      wx:for="{{currentQuestion.options}}" 
      wx:key="index"
      class="option-item card {{getOptionClass(index)}}"
      bindtap="selectOption"
      data-index="{{index}}"
    >
      <view class="option-letter">{{getLetter(index)}}</view>
      <view class="option-text">{{item}}</view>
      <view class="option-status">
        <text wx:if="{{selectedAnswer === index && showResult}}" class="result-icon">
          {{index === currentQuestion.answer ? '✓' : '✗'}}
        </text>
      </view>
    </view>
  </view>

  <view class="explanation-card card" wx:if="{{showResult}}">
    <view class="explanation-icon">💡</view>
    <view class="explanation-content">
      <view class="explanation-title">解析</view>
      <view class="explanation-text">{{currentQuestion.explanation}}</view>
    </view>
  </view>

  <view class="action-buttons">
    <view class="hint-btn" bindtap="showHint">
      <text class="hint-icon">💡</text>
      <text class="hint-text">查看提示</text>
    </view>
    <view 
      class="next-btn btn-primary" 
      wx:if="{{showResult}}"
      bindtap="nextQuestion"
    >
      {{currentIndex < totalQuestions - 1 ? '下一题' : '查看结果'}}
    </view>
  </view>

  <view class="hint-modal" wx:if="{{showHintModal}}">
    <view class="hint-content card">
      <view class="hint-title">💡 提示</view>
      <view class="hint-text">{{currentQuestion.hint}}</view>
      <view class="hint-btn-area">
        <view class="close-hint btn-secondary" bindtap="closeHint">关闭</view>
      </view>
    </view>
  </view>
</view>