.container {
  min-height: 100vh;
  background: #f0f5f9;
  padding: 0 30rpx 200rpx;
}

.progress-bar {
  height: 8rpx;
  background: #e0e0e0;
  border-radius: 4rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #1890ff, #096dd9);
  border-radius: 4rpx;
  transition: width 0.3s;
}

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
}

.progress-text {
  font-size: 26rpx;
  color: #666;
}

.type-tag {
  font-size: 22rpx;
  color: #fff;
  background: #fa8c16;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.question-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.question-text {
  font-size: 32rpx;
  color: #333;
  line-height: 1.8;
}

.options-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.option-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  border: 4rpx solid transparent;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

/* 选中状态 */
.option-item.selected {
  border-color: #1890ff;
  background: #e6f7ff;
}

/* 正确状态 */
.option-item.correct {
  border-color: #52c41a;
  background: #f6ffed;
}

/* 错误状态 */
.option-item.wrong {
  border-color: #ff4d4f;
  background: #fff1f0;
}

.option-letter {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: bold;
  color: #666;
  margin-right: 20rpx;
}

.option-letter.selected {
  background: #1890ff;
  color: #fff;
}

.option-letter.correct {
  background: #52c41a;
  color: #fff;
}

.option-letter.wrong {
  background: #ff4d4f;
  color: #fff;
}

.option-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.bottom-bar {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.action-btn {
  font-size: 26rpx;
  color: #666;
  padding: 16rpx 30rpx;
  background: #fff;
  border-radius: 30rpx;
}

.hint-btn {
  color: #fa8c16;
}

.collect-btn {
  color: #1890ff;
}

.confirm-btn, .next-btn {
  background: linear-gradient(135deg, #1890ff, #096dd9);
  color: #fff;
  text-align: center;
  padding: 30rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.result-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-top: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.result-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.result-icon {
  font-size: 40rpx;
  margin-right: 12rpx;
}

.result-text {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.explanation {
  background: #f9f9f9;
  border-radius: 12rpx;
  padding: 20rpx;
}

.exp-label {
  font-size: 26rpx;
  color: #1890ff;
  font-weight: bold;
}

.exp-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.hint-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.hint-content {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  width: 600rpx;
  max-width: 90%;
}

.hint-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.hint-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.hint-close {
  font-size: 50rpx;
  color: #ccc;
  padding: 0 10rpx;
}

.hint-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}
