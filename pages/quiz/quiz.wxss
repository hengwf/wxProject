.quiz-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  position: relative;
  z-index: 1;
}

.progress-info {
  flex: 1;
  margin-right: 24rpx;
}

.progress-bar {
  height: 16rpx;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0.2), rgba(255, 255, 255, 0.1));
  border-radius: 8rpx;
  overflow: hidden;
  box-shadow: inset 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
  background-size: 200% 100%;
  animation: progressGradient 2s ease infinite;
  border-radius: 8rpx;
  transition: width 0.6s cubic-bezier(0.68, -0.55, 0.265, 1.55);
  box-shadow: 0 0 20rpx rgba(102, 126, 234, 0.5);
}

@keyframes progressGradient {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

.progress-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-top: 12rpx;
  font-weight: 600;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
}

.score-info {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, rgba(82, 196, 26, 0.2) 0%, rgba(82, 196, 26, 0.1) 100%);
  backdrop-filter: blur(10rpx);
  padding: 14rpx 24rpx;
  border-radius: 30rpx;
  border: 2rpx solid rgba(82, 196, 26, 0.3);
  box-shadow: 0 4rpx 16rpx rgba(82, 196, 26, 0.2);
}

.correct-icon {
  color: #52c41a;
  font-size: 32rpx;
  margin-right: 10rpx;
  animation: correctBounce 1s ease-in-out infinite;
}

@keyframes correctBounce {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.correct-count {
  font-size: 30rpx;
  font-weight: 800;
  color: #52c41a;
  text-shadow: 0 2rpx 8rpx rgba(82, 196, 26, 0.3);
}

.question-card {
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.question-number {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 18rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.question-text {
  font-size: 36rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #333 0%, #667eea 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  line-height: 1.6;
  letter-spacing: 1rpx;
}

.options-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
}

.option-item {
  display: flex;
  align-items: center;
  padding: 32rpx !important;
  transition: all 0.3s cubic-bezier(0.68, -0.55, 0.265, 1.55);
  border: 3rpx solid transparent;
  position: relative;
  overflow: hidden;
}

.option-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(102, 126, 234, 0.1), transparent);
  transition: left 0.5s ease;
}

.option-item:active:not(.option-disabled):not(.option-correct):not(.option-wrong)::before {
  left: 100%;
}

.option-item:active:not(.option-disabled):not(.option-correct):not(.option-wrong) {
  transform: scale(0.96);
  border-color: #667eea;
  box-shadow: 0 8rpx 32rpx rgba(102, 126, 234, 0.3);
}

.option-letter {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #f5f7fa 0%, #e8ecf1 100%);
  border-radius: 50%;
  font-size: 28rpx;
  font-weight: 800;
  color: #666;
  margin-right: 24rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1), inset 0 2rpx 4rpx rgba(255, 255, 255, 0.8);
  transition: all 0.3s ease;
}

.option-text {
  flex: 1;
  font-size: 32rpx;
  color: #444;
  font-weight: 600;
  line-height: 1.5;
}

.option-status {
  margin-left: 20rpx;
}

.result-icon {
  font-size: 36rpx;
  font-weight: bold;
  animation: resultPop 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55);
}

@keyframes resultPop {
  0% { transform: scale(0) rotate(-180deg); }
  100% { transform: scale(1) rotate(0deg); }
}

.option-correct {
  background: linear-gradient(135deg, #f6ffed 0%, #d4edda 100%) !important;
  border-color: #52c41a !important;
  box-shadow: 0 8rpx 32rpx rgba(82, 196, 26, 0.3), inset 0 2rpx 8rpx rgba(255, 255, 255, 0.8);
  animation: correctGlow 0.6s ease-out;
}

@keyframes correctGlow {
  0% { box-shadow: 0 0 0 0 rgba(82, 196, 26, 0.7); }
  100% { box-shadow: 0 8rpx 32rpx rgba(82, 196, 26, 0.3), inset 0 2rpx 8rpx rgba(255, 255, 255, 0.8); }
}

.option-correct .option-letter {
  background: linear-gradient(135deg, #52c41a 0%, #389e0d 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(82, 196, 26, 0.4);
  animation: letterSpin 0.5s ease-out;
}

@keyframes letterSpin {
  0% { transform: rotate(0deg) scale(0.5); }
  50% { transform: rotate(180deg) scale(1.2); }
  100% { transform: rotate(360deg) scale(1); }
}

.option-correct .result-icon {
  color: #52c41a;
  filter: drop-shadow(0 0 8rpx rgba(82, 196, 26, 0.5));
}

.option-wrong {
  background: linear-gradient(135deg, #fff2f0 0%, #f8d7da 100%) !important;
  border-color: #f5222d !important;
  box-shadow: 0 8rpx 32rpx rgba(245, 34, 45, 0.3), inset 0 2rpx 8rpx rgba(255, 255, 255, 0.8);
  animation: shake 0.5s ease-in-out;
}

.option-wrong .option-letter {
  background: linear-gradient(135deg, #f5222d 0%, #cf1322 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(245, 34, 45, 0.4);
}

.option-wrong .result-icon {
  color: #f5222d;
  filter: drop-shadow(0 0 8rpx rgba(245, 34, 45, 0.5));
}

.option-disabled {
  opacity: 0.5;
  filter: grayscale(50%);
}

.explanation-card {
  display: flex;
  padding: 28rpx !important;
  background: linear-gradient(135deg, #fffbe6 0%, #fff3cd 100%) !important;
  border: 3rpx solid #ffe066;
  box-shadow: 0 8rpx 24rpx rgba(255, 193, 7, 0.2), inset 0 2rpx 8rpx rgba(255, 255, 255, 0.9);
  position: relative;
  z-index: 1;
  animation: explanationPop 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
}

@keyframes explanationPop {
  0% { transform: scale(0.8) translateY(20rpx); opacity: 0; }
  100% { transform: scale(1) translateY(0); opacity: 1; }
}

.explanation-icon {
  font-size: 44rpx;
  margin-right: 20rpx;
  animation: iconWiggle 1s ease-in-out infinite;
}

@keyframes iconWiggle {
  0%, 100% { transform: rotate(-5deg); }
  50% { transform: rotate(5deg); }
}

.explanation-content {
  flex: 1;
}

.explanation-title {
  font-size: 28rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #d4a017 0%, #ffc107 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 10rpx;
  letter-spacing: 2rpx;
}

.explanation-text {
  font-size: 28rpx;
  color: #997a13;
  line-height: 1.7;
  font-weight: 500;
}

.action-buttons {
  display: flex;
  gap: 24rpx;
  margin-top: 24rpx;
  position: relative;
  z-index: 1;
}

.hint-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx;
  background: linear-gradient(135deg, #fff7e6 0%, #ffeedd 100%);
  border: 3rpx solid #ffc107;
  border-radius: 50rpx;
  color: #d46b08;
  box-shadow: 0 8rpx 24rpx rgba(255, 193, 7, 0.2), inset 0 2rpx 8rpx rgba(255, 255, 255, 0.9);
  transition: all 0.3s ease;
}

.hint-btn:active {
  transform: scale(0.96);
  box-shadow: 0 4rpx 12rpx rgba(255, 193, 7, 0.2);
}

.hint-icon {
  font-size: 36rpx;
  margin-right: 14rpx;
  animation: hintSpin 2s ease-in-out infinite;
}

@keyframes hintSpin {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(-10deg); }
  75% { transform: rotate(10deg); }
}

.hint-text {
  font-size: 30rpx;
  font-weight: 700;
}

.next-btn {
  flex: 2;
}

.hint-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, rgba(102, 126, 234, 0.8) 0%, rgba(118, 75, 162, 0.8) 100%);
  backdrop-filter: blur(20rpx);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  z-index: 100;
  animation: modalFade 0.3s ease-out;
}

@keyframes modalFade {
  0% { opacity: 0; }
  100% { opacity: 1; }
}

.hint-content {
  width: 100%;
  text-align: center;
  animation: contentPop 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
}

@keyframes contentPop {
  0% { transform: scale(0.8); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

.hint-title {
  font-size: 36rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #667eea 0%, #f093fb 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 24rpx;
  letter-spacing: 3rpx;
}

.hint-text {
  font-size: 30rpx;
  color: #444;
  line-height: 1.7;
  margin-bottom: 36rpx;
  font-weight: 600;
}

.hint-btn-area {
  display: flex;
  justify-content: center;
}

.close-hint {
  padding: 24rpx 72rpx;
}